{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/login/login",
			"style": {
				"navigationBarTitleText": "登录",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/index/index",
			"style": {
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/intro/intro",
			"style": {
				"navigationBarTitleText": "工作室介绍"
			}
		},
		{
			"path": "pages/dynamic/dynamic",
			"style": {
				"navigationBarTitleText": "工作动态"
			}
		},
		{
			"path": "pages/question/question",
			"style": {
				"navigationBarTitleText": "问题咨询",
				"disableScroll": true,
				"navigationBarBackgroundColor": "#fff"
			}
		},
		{
			"path": "pages/technologyTransfer/technologyTransfer",
			"style": {
				"navigationBarTitleText": "需求详情",
				"navigationBarBackgroundColor": "#fff"
			}
		},
		{
			"path": "pages/dynamic/compontes/dynamicDetail/dynamicDetail",
			"style": {
				"navigationBarTitleText": "工作动态详情"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	}
}